{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Netwatch",
  "version": "1.0.0",
  "identifier": "com.coerie.netwatch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Netwatch - Local Network Monitor",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/netwatch-backend"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}